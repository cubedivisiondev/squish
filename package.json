{
  "name": "squish",
  "version": "1.0.0",
  "description": "Compress or convert any file to an exact file size, at the best quality that fits under it. 100% in your browser, nothing uploaded.",
  "keywords": [
    "compression",
    "image-compression",
    "video-compression",
    "gif",
    "pdf",
    "pwa",
    "webassembly",
    "ffmpeg-wasm",
    "client-side",
    "file-size",
    "privacy"
  ],
  "homepage": "https://cubedivisiondev.github.io/squish/",
  "bugs": {
    "url": "https://github.com/cubedivisiondev/squish/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cubedivisiondev/squish.git"
  },
  "license": "MIT",
  "author": "PUDDY Inc.",
  "private": false,
  "scripts": {
    "start": "npx --yes http-server . -p 5173 -c-1 -o",
    "serve": "npx --yes serve .",
    "check": "node --check app.js && node --check sw.js"
  }
}
